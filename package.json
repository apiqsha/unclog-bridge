{
  "name": "unclog-bridge",
  "version": "1.1.1",
  "description": "Persistent thin local MCP bridge for hosted Unclog.",
  "license": "SEE LICENSE IN LICENSE",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apiqsha/unclog-bridge.git"
